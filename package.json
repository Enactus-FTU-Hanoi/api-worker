{
  "name": "enactus-ftu-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply enactus-ftu-db",
    "db:migrate:local": "wrangler d1 migrations apply enactus-ftu-db --local",
    "db:seed": "wrangler d1 execute enactus-ftu-db --local --file=migrations/seed.sql",
    "db:seed-admin": "wrangler d1 execute enactus-ftu-db --local --file=migrations/seed-admin.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.65.0"
  }
}
